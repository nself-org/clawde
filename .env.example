# ClawDE Monorepo — Environment Configuration
# Per-app env files live in apps/desktop/.env.example and apps/mobile/.env.example.
# Copy this to .env (gitignored) for shared/root-level overrides.
# Client-exposed vars (VITE_*, EXPO_PUBLIC_*) are inlined into bundles — never put secrets here.

# Runtime environment: development | staging | production
APP_ENV=development

# Desktop (Tauri + Vite) — see apps/desktop/.env.example
VITE_APP_ENV=development
VITE_APP_VERSION=0.1.0
VITE_NSELF_SENTRY_DSN=

# Mobile (Expo) — see apps/mobile/.env.example
EXPO_PUBLIC_APP_VERSION=0.1.0
EXPO_PUBLIC_SENTRY_DSN=
