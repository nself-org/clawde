{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "bundleIdentifier": "io.clawde.mobile"
      },
      "android": {
        "buildType": "app-bundle",
        "applicationId": "io.clawde.mobile"
      }
    },
    "bundle": {
      "distribution": "store",
      "env": {
        "NSELF_BUNDLE": "clawde"
      },
      "ios": {
        "bundleIdentifier": "io.clawde.mobile.bundle"
      },
      "android": {
        "buildType": "app-bundle",
        "applicationId": "io.clawde.mobile.bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "alisalaah@gmail.com",
        "ascAppId": "",
        "appleTeamId": ""
      },
      "android": {
        "serviceAccountKeyPath": "../../.claude/keys/play-service-account.json",
        "track": "internal"
      }
    }
  }
}
