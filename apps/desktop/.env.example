# ClawDE Desktop (Tauri 2 + Vite) — Environment Configuration
# Copy to .env (gitignored) and fill in per-environment values.
# VITE_* vars are inlined into the client bundle — never put secrets here.

# Runtime environment: development | staging | production
VITE_APP_ENV=development

# App version surfaced in the UI / diagnostics (usually set from package.json at build)
VITE_APP_VERSION=0.1.0

# Sentry DSN for client error reporting (leave empty to disable)
VITE_NSELF_SENTRY_DSN=
