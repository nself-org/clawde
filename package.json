{
  "name": "clawde",
  "version": "0.3.5",
  "private": true,
  "description": "ClawDE — AI dev environment JS/TS workspace root (RN mobile + @nself/* shared packages)",
  "scripts": {
    "mobile": "pnpm --filter @clawde/mobile start",
    "mobile:ios": "pnpm --filter @clawde/mobile ios",
    "mobile:android": "pnpm --filter @clawde/mobile android",
    "typecheck": "pnpm -r run type-check",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "markdown-it@<12.3.2": ">=12.3.2",
      "esbuild@<=0.24.2": ">=0.25.0",
      "vite@<=6.4.1": ">=6.4.2",
      "postcss@<8.5.10": ">=8.5.10",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "@xmldom/xmldom@<0.8.13": ">=0.8.13",
      "uuid@<11.1.1": ">=11.1.1",
      "vitest@<3.2.6": ">=3.2.6",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1",
      "vite@<=6.4.2": ">=6.4.3",
      "js-yaml@<=4.1.1": ">=4.2.0",
      "markdown-it@<=14.1.1": ">=14.2.0",
      "dompurify@<=3.4.10": ">=3.4.11"
    }
  }
}
